{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kvasir",
  "version": "0.1.0",
  "identifier": "com.johnny.kvasir",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Kvasir",
        "width": 1200,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "json", "jsonl", "jsonld", "json-ld",
          "yaml", "yml", "toml", "tomlx", "ron",
          "csv", "tsv",
          "ini", "cfg", "conf", "env",
          "md", "txt", "rst",
          "py", "rs", "js", "ts", "svelte", "html", "css",
          "sh", "zsh", "bash",
          "rb", "go", "java", "c", "cpp", "h", "hpp",
          "swift", "lua", "sql", "zig",
          "qa", "meta", "index",
          "bak",
          "log", "diff", "xml", "svg"
        ],
        "name": "Text File",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
